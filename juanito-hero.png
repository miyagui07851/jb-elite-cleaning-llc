
:root{--navy:#062b53;--navy2:#031b35;--gold:#e7aa20;--gold2:#f6c247;--ink:#071d3b;--muted:#5d6f86;--soft:#f4f9ff;--line:#dce8f4;--white:#fff;--shadow:0 18px 45px rgba(4,25,55,.14)}
*{box-sizing:border-box}html{scroll-behavior:auto}body{margin:0;font-family:Inter,Arial,Helvetica,sans-serif;color:var(--ink);background:#fff;cursor:url('../images/spray-cursor.png') 8 6,auto}a,button,input,select,textarea{cursor:url('../images/spray-cursor.png') 8 6,pointer}img{max-width:100%;display:block}.container{width:min(1120px,92vw);margin:0 auto}.header{background:linear-gradient(135deg,var(--navy2),var(--navy));height:96px;display:flex;align-items:center;position:sticky;top:0;z-index:1000;box-shadow:0 8px 25px rgba(0,0,0,.12)}.nav{display:flex;align-items:center;justify-content:space-between;gap:25px}.brand{display:flex;align-items:center;gap:12px;text-decoration:none}.brand img{height:74px;width:auto;max-width:235px;object-fit:contain}.menu{display:flex;align-items:center;gap:30px}.menu a{color:white;text-decoration:none;text-transform:uppercase;font-size:14px;font-weight:900;letter-spacing:.02em}.menu a:hover{color:var(--gold2)}.btn{border:0;border-radius:8px;padding:16px 28px;background:linear-gradient(180deg,var(--gold2),var(--gold));color:#061b34;text-decoration:none;font-weight:950;text-transform:uppercase;letter-spacing:.02em;box-shadow:0 14px 25px rgba(231,170,32,.25);display:inline-flex;align-items:center;justify-content:center}.btn.outline{background:white;border:2px solid var(--ink);box-shadow:none}.hero{padding:58px 0 34px;background:linear-gradient(90deg,#fff 0%,#fff 54%,#eff7ff 100%);overflow:hidden}.hero-grid{display:grid;grid-template-columns:1fr 1.05fr;align-items:center;gap:48px}.eyebrow{color:#d99a00;font-weight:950;letter-spacing:.22em;text-transform:uppercase;font-size:14px}.hero h1{font-size:clamp(46px,6vw,72px);line-height:.97;margin:22px 0 22px;font-weight:1000;letter-spacing:-.05em;color:var(--ink)}.hero h1 span{color:var(--gold)}.lead{font-size:18px;line-height:1.7;max-width:520px}.hero-icons{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin:32px 0}.icon-pill{text-align:center;font-weight:950;font-size:14px}.circle{width:58px;height:58px;border-radius:50%;background:var(--navy2);display:grid;place-items:center;margin:0 auto 9px;color:var(--gold);font-size:25px}.hero-actions{display:flex;gap:16px;flex-wrap:wrap}.hero-art{position:relative;min-height:520px;display:flex;align-items:center;justify-content:flex-end}.hero-art .bottle{position:absolute;left:18px;top:78px;width:160px;transform:rotate(-7deg);filter:drop-shadow(0 15px 20px rgba(5,30,65,.16))}.hero-art .juanito{width:min(455px,90%);filter:drop-shadow(0 20px 35px rgba(6,42,80,.22));margin-right:0}.speech{position:absolute;left:100px;bottom:90px;background:#fff;border:3px solid #095db3;border-radius:30px;padding:18px 24px;text-align:center;font-weight:950;color:var(--ink);box-shadow:0 16px 25px rgba(0,0,0,.12);line-height:1.05}.speech:after{content:"";position:absolute;right:35px;bottom:-18px;border:10px solid transparent;border-top-color:#095db3}.speech b{font-size:29px;color:#095db3}.serving{background:var(--navy);color:white;border-radius:8px;display:flex;align-items:center;gap:26px;padding:22px 28px;margin:0 auto 28px;box-shadow:var(--shadow);flex-wrap:wrap}.serving strong{color:var(--gold);letter-spacing:.08em}.serving span{font-weight:850}.estimate-box{background:linear-gradient(135deg,var(--navy2),#083d73);border-radius:12px;color:white;padding:32px 44px;margin:0 auto 52px;box-shadow:var(--shadow)}.center{text-align:center}.estimate-grid{display:grid;grid-template-columns:1fr 1fr;gap:45px;align-items:center}.field{margin:12px 0}.field label{display:block;font-weight:850;margin-bottom:7px}.field input,.field select,.field textarea{width:100%;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);border-radius:8px;color:white;padding:14px}.field option{color:#071d3b}.price{font-size:44px;color:var(--gold);font-weight:1000;margin:10px 0}.section{padding:26px 0 56px}.section h2{font-size:34px;text-align:center;margin:8px 0 24px}.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}.service-card{background:#fff;border:1px solid var(--line);border-radius:10px;box-shadow:0 12px 30px rgba(4,25,55,.08);overflow:hidden;text-align:center}.service-card img{height:150px;width:100%;object-fit:cover}.service-card .body{padding:20px}.service-card h3{margin:0 0 8px}.why-grid{display:grid;grid-template-columns:.75fr 1.25fr;gap:45px;align-items:center}.check{list-style:none;padding:0;margin:16px 0}.check li{margin:11px 0;font-weight:700}.check li:before{content:'✓';display:inline-grid;place-items:center;width:21px;height:21px;border-radius:50%;background:var(--gold);color:var(--ink);font-weight:1000;margin-right:9px}.photo{border-radius:13px;box-shadow:var(--shadow);overflow:hidden}.page-hero{padding:70px 0;background:linear-gradient(90deg,#fff 0%,#fff 60%,#eff7ff 100%);border-bottom:1px solid var(--line)}.page-hero h1{font-size:58px;line-height:1;margin:12px 0}.content-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:30px}.info-card{background:white;border:1px solid var(--line);border-radius:14px;padding:28px;box-shadow:0 14px 36px rgba(4,25,55,.08)}.steps{counter-reset:s}.steps .info-card:before{counter-increment:s;content:counter(s);width:42px;height:42px;border-radius:50%;background:var(--gold);display:grid;place-items:center;font-weight:1000;margin-bottom:15px}.footer{background:var(--navy2);color:white;padding:38px 0;margin-top:30px}.footer-grid{display:grid;grid-template-columns:1.2fr 1fr 1fr;gap:25px}.chat-widget{position:fixed;left:24px;bottom:24px;z-index:2000}.chat-bubble{display:flex;align-items:center;gap:10px;background:white;border:0;border-radius:35px;padding:9px 18px 9px 10px;box-shadow:0 18px 40px rgba(3,24,50,.2);font-weight:950;color:var(--ink);position:relative}.chat-bubble img{width:48px;height:60px;object-fit:contain}.chat-bubble b{color:#095db3;font-size:19px}.chat-close{position:absolute;right:9px;top:5px;border:0;background:transparent;font-size:18px;color:#223}.chat-panel{position:absolute;left:0;bottom:83px;width:330px;background:white;border-radius:18px;box-shadow:0 20px 60px rgba(3,24,50,.25);overflow:hidden;display:none}.chat-panel.open{display:block}.chat-head{background:var(--navy);color:white;font-weight:950;padding:14px 18px;display:flex;justify-content:space-between}.chat-head button{background:transparent;color:white;border:0;font-size:20px}.chat-body{padding:18px}.quick{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:12px 0}.quick button,.chat-send{background:var(--navy);color:white;border:0;border-radius:8px;padding:11px;font-weight:900}.chat-input{display:flex;gap:8px}.chat-input input{flex:1;padding:10px;border:1px solid var(--line);border-radius:8px}.to-top{position:fixed;right:26px;bottom:26px;width:45px;height:45px;border-radius:50%;background:var(--gold);display:grid;place-items:center;color:var(--ink);text-decoration:none;font-weight:1000;box-shadow:var(--shadow)}
@media(max-width:900px){.header{height:auto;padding:14px 0}.nav{flex-direction:column}.menu{gap:14px;flex-wrap:wrap;justify-content:center}.hero-grid,.estimate-grid,.why-grid,.content-grid{grid-template-columns:1fr}.hero-art{min-height:auto;justify-content:center}.hero-art .bottle{left:8%;top:5%;width:120px}.speech{left:8%;bottom:35px}.cards{grid-template-columns:1fr}.serving{justify-content:center}.footer-grid{grid-template-columns:1fr}.brand img{height:58px}.hero h1{font-size:48px}.chat-panel{width:300px}.hero-icons{grid-template-columns:repeat(2,1fr)}}
