
function calc(){const sqft=document.getElementById('sqft');if(!sqft)return;const freq=document.getElementById('freq'),type=document.getElementById('type'),price=document.getElementById('price');let s=parseFloat(sqft.value)||0;let base=Math.max(220,s*.10);let low=Math.round(base*parseFloat(freq.value)*parseFloat(type.value));let high=Math.round(low*1.3);price.textContent=`$${low.toLocaleString()} - $${high.toLocaleString()}`;}['sqft','freq','type'].forEach(id=>{let el=document.getElementById(id);if(el)el.addEventListener('input',calc)});calc();
const bubble=document.getElementById('openChat'),panel=document.getElementById('chatPanel');if(bubble){bubble.addEventListener('click',e=>{if(e.target.id==='hideBubble')return;panel.classList.toggle('open')});document.getElementById('closePanel').onclick=()=>panel.classList.remove('open');document.getElementById('hideBubble').onclick=(e)=>{e.stopPropagation();document.querySelector('.chat-widget').style.display='none'};document.querySelectorAll('[data-go]').forEach(b=>b.onclick=()=>location.href=b.dataset.go+'.html');document.getElementById('ask').onclick=()=>{const q=document.getElementById('question').value.toLowerCase();let page='services.html'; if(q.includes('quote')||q.includes('price')||q.includes('cost')) page='estimate.html'; else if(q.includes('area')||q.includes('bronx')||q.includes('yonkers')||q.includes('westchester')) page='areas.html'; else if(q.includes('contact')||q.includes('call')||q.includes('email')) page='contact.html'; location.href=page;};}
